  "keyFeatures": [
    "Diacritic-insensitive Arabic text matching and regex generation",
    "Single-pass Arabic preformatting pipeline optimized for large datasets",
    "Rich typography normalizers for punctuation, quotes, brackets, and whitespace",
    "LLM-aware token estimation supporting OpenAI, Gemini, Claude, and Grok",
    "Transliteration cleanup and salutation normalization for classical Islamic texts",
    "Sanitization pipelines for removing references, URLs, and markdown artifacts"
  ],
  "publicApiSurface": [
    "makeDiacriticInsensitiveRegex",
    "preformatArabicText",
    "estimateTokenCount",
    "replaceSalutationsWithSymbol",
    "arabicNumeralToNumber",
    "getArabicScore",
    "removeMarkdownFormatting",
    "applySmartQuotes",
    "normalizeArabicPrefixesToAl",
    "parsePageRanges",
    "isBalanced",
    "normalizeJsonSyntax",
    "toTitleCase",
    "truncate",
    "truncateMiddle",
    "condenseEllipsis",
    "cleanSymbolsAndPartReferences"
  ]
